		title: Aragorn
		subtitle: King of Gondor and Arnor
		unique: true
		side: Free Peoples
		culture: Gondor
		twilight: 5
		type: Companion
		race: Man
		strength: 8
		vitality: 4
		signet: Aragorn
		resistance: 6
		effects: [
			{
				type: Modifier
				modifier: {
					type: ModifyStrength
					filter: self
					amount: 1
					requires: {
						type: CanSpot
						filter: Rohan, Man
						count: 1
					}
				}
			}

			{
				type: Modifier
				modifier: {
					type: ModifyStrength
					filter: self
					amount: 1
					requires: {
						type: CanSpot
						filter: other, Gondor, Man
						count: 1
					}
				}
			}
			{
				type: Trigger
				optional: true
				trigger: {
					type: Moves
				}
				cost: [
					{
						type: Exert
						select: self
					}
					{
						type: Hinder
						select: choose(another,unbound,Man)
					}
				]
				effect: {
					type: Choice
					texts: [
						Remove a threat
						Remove a burden
					]
					effects: [
						{
							type: RemoveThreats
							amount: 1
						}
						{
							type: RemoveBurdens
							amount: 1
						}
					]
				}
			}
		]
		gametext: Aragorn is strength +1 for each other Man of a different culture you can spot.<br>Each time the fellowship moves, you may exert Aragorn and hinder another unbound Man to remove a threat or a burden.
		lore: "'Stand, Men of the West! This is the hour of doom.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
