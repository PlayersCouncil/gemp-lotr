	103_30: {
		cardInfo: {
			//id: 103_30.1
			parent: 103_30
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S030.1_card.jpg
			collInfo: V3_30
			rarity: _
		}
		title: Northern Signal-fire
		subtitle: Flame of Nardol
		unique: 2
		side: Free Peoples
		culture: Gondor
		twilight: 2
		type: Possession
		target: self
		keywords: [
			Beacon
			Support Area
		]
		effects: [
			{
				type: ExtraCost
				cost: [
					{
						type: Hinder
						select: choose(beacon)
						count: 2
					}
				]
			}

			{
				type: Activated
				phase: Archery
				cost: [
					{
						type: Hinder
						select: choose(beacon)
						count: {
							type: Range
							from: 1
							to: {
								type: ForEachYouCanSpot
								filter: hinderable, beacon
							}
						}
						memorize: hinderedBeacons
					}
					{
						type: Discard
						select: choose(or(Gondor, Rohan), or(condition, possession))
						count: {
							type: ForEachInMemory
							memory: hinderedBeacons
						}
						memorize: discardedCards
					}
				]
				effect: {
					type: ModifyArcheryTotal
					amount: {
						type: ForEachInMemory
						memory: hinderedBeacons
					}
					side: Free Peoples
				}
			}
		]
		gametext: Beacon. To play, hinder 2 beacons.<br>Archery: Hinder X beacons and discard X [Gondor] or [Rohan] conditions or possessions to make the fellowship archery total +X.
		lore: "'What is that?' cried Pippin suddenly, clutching at Gandalf's cloak. 'Look! Fire, red fire! Are there dragons in this land? Look, there is another!'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

	103_36: {
		cardInfo: {
			//id: 103_36.1
			parent: 103_36
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S036.1_card.jpg
			collInfo: V3_36
			rarity: _
		}
		title: The Way is Shut
		unique: false
		side: Free Peoples
		culture: Gondor
		twilight: 1
		type: Event
		timewords: [
			Maneuver
			Skirmish
		]
		effects: [
			{
				type: event
				
				cost: {
					type: If
					check: {
						type: Phase
						phase: Maneuver
					}
					true: {
						type: Spot
						filter: Gondor, Wraith
						count: 3
					}
				}
				
				effect: {
					type: If
					check: {
						type: Phase
						phase: Maneuver
					}
					true: [
						{
							type: Discard
							select: choose(side(Shadow), condition)
						}
						{
							type: Optional
							text: Would you like to exert a Wraith to hinder another Shadow condition?
							cost: {
								type: Exert
								select: choose(Wraith)
							}
							effect: {
								type: Hinder
								select: choose(side(Shadow), condition)
							}
						}
					]
					false: {
						type: ModifyStrength
						select: choose(your,Wraith)
						amount: {
							type: ForEachThreat
							limit: 3
						}
					}
				}
			}
		]
		gametext: Maneuver: Spot 3 [gondor] Wraiths to discard a Shadow condition.  You may exert a Wraith to hinder another Shadow condition.<br>Skirmish: Make your Wraith strength +1 for each threat you can spot (limit +3).
		lore: "'Is it then your errand to seek death? For that is all that you will find on that road. They do not suffer the living to pass.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

