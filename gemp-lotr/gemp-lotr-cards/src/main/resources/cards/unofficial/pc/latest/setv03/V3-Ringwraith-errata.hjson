	103_79: {
		cardInfo: {
			//id: 103_79.1
			parent: 103_79
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S079.1_card.jpg
			collInfo: V3_79
			rarity: _
		}
		title: Ulaire Toldea
		subtitle: Blessed with Brutality
		unique: true
		side: Shadow
		culture: Wraith
		twilight: 7
		type: Minion
		race: Nazgul
		strength: 13
		vitality: 3
		site: 3
		keywords: Fierce
		effects: [
			{
				type: trigger
				optional: true
				trigger: {
					type: AssignedAgainst
					filter: companion
					against: self
					memorizeAssigned: comp
				}
				requires: {
					type: IsNotEqual
					firstNumber: {
						type: ForEachStrength
						filter: self
					}
					secondNumber: {
						type: ForEachStrength
						filter: memory(comp)
					}
				}
				effect: [
					{
						type: If
						check: {
							type: IsLessThan
							firstNumber: {
								type: ForEachStrength
								filter: self
							}
							secondNumber: {
								type: ForEachStrength
								filter: memory(comp)
							}
						}
						true: {
							type: CostToEffect
							cost: {
								type: Exhaust
								select: self
							}
							effect: {
								type: Hinder
								select: memory(comp)
							}
						}
					}
					{
						type: If
						check: {
							type: IsGreaterThan
							firstNumber: {
								type: ForEachStrength
								filter: self
							}
							secondNumber: {
								type: ForEachStrength
								filter: memory(comp)
							}
						}
						true: {
							type: CostToEffect
							cost: {
								type: Exert
								select: self
							}
							effect: {
								type: Choice
								texts: [
									Exert that companion
									Add a threat
								]
								effects: [
									{
										type: Exert
										select: memory(comp)
									}
									{
										type: AddThreats
										amount: 1
									}
								]
							}
						}
					}
				]
			}
		]
		gametext: Fierce.<br>Each time this minion is assigned to a stronger companion, you may exhaust this minion to hinder that companion.<br>Each time this minion is assigned to a weaker companion, you may exert this minion to exert that companion or add a threat.
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

	103_80: {
		cardInfo: {
			//id: 103_80.1
			parent: 103_80
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S080.1_card.jpg
			collInfo: V3_80
			rarity: _
		}
		title: The Witch-king
		subtitle: Empowered by His Master
		unique: true
		side: Shadow
		culture: Wraith
		twilight: 10
		type: Minion
		race: Nazgul
		strength: 15
		vitality: 4
		site: 3
		keywords: [
			Enduring
			Damage+1
		]
		effects: [
			{
				type: trigger
				optional: false
				trigger: {
					type: Played
					filter: self
				}
				requires: {
					type: CanSpot
					filter: another,Nazgul
				}
				effect: [
					{
						type: ChooseActiveCards
						select: choose(side(freeps),not(companion))
						text: Choose a card type to hinder
						memorize: chosenCard
					}
					{
						type: Hinder
						select: all(side(freeps),CardTypeFromMemory(chosenCard))
					}
					{
						type: ChooseActiveCards
						player: freeps
						count: any
						select: choose(your,hindered)
						hindered: true
						text: Choose any number of cards to restore (you will exert a character for each)
						memorize: restoredCards
					}
					{
						type: Restore
						select: all(memory(restoredCards))
					}
					{
						type: Repeat
						times: {
							type: ForEachInMemory
							memory: restoredCards
						}
						effect: {
							type: Exert
							player: Free Peoples
							count: 1
							select: choose(side(Free Peoples), character, canExert)
						}
					}
				]
			}
		]
		gametext: Enduring. Damage +1.<br>When you play this minion, spot another Nazgul to hinder all Free Peoples cards of one type (except companion). The Free Peoples player may restore any number of their cards, and must exert one of their characters for each card restored.
		lore: "From a mouth unseen there came a deadly laughter."
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

