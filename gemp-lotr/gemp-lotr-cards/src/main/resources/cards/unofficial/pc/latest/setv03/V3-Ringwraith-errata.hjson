			{
				type: Trigger
				optional: true
				trigger: {
					type: Played
					player: you
					filter: ringwraith,orc
				}
				requires: {
					type: playedCardThisPhase
					filter: ringwraith,orc
					min: 2
					max: 2
				}
				effect: {
					type: Hinder
					player: freeps
					select: choose(side(freeps),possession)
				}
			}
			{
				type: Activated
				phase: Shadow
				cost: {
					type: Spot
					filter: Nazgul
				}
				effect: [
					{
						type: doWhile
						effect: {
							type: playCardFromDiscard
							optional: true
							select: choose(possession)
