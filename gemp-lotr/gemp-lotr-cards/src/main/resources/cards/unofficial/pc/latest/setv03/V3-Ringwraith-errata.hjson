	103_69: {
		cardInfo: {
			//id: 103_69.1
			parent: 103_69
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S069.1_card.jpg
			collInfo: V3_69
			rarity: _
		}
		title: No Man May Hinder Me
		unique: false
		side: Shadow
		culture: Wraith
		twilight: 3
		type: Event
		timewords: [
			Maneuver
			Skirmish
		]
		effects: [
			{
				type: event
				effect: [
					{
						type: Restore
						select: choose(Nazgul)
					}
					{
						type: Optional
						text: Would you like to exert The Witch-king twice to hinder all Free Peoples possessions?
						requires: {
							type: CanSpot
							filter: title(The Witch-king),CanExert, MinVitality(3)
						}
						cost: {
							type: Exert
							select: choose(title(The Witch-king))
							times: 2
						}
						effect: {
							type: Hinder
							select: all(side(freeps),possession)
						}
					}
				]
			}
		]
		gametext: <b>Maneuver</b> <i>or</i> <b>Skirmish</b>: Restore a Nazgul. Then you may exert The Witch-king twice to hinder all Free Peoples possessions.
		lore: "'Yet now under the Lord of Barad-dur the most fell<br>of all his captains is already master of your outer walls,' said Gandalf. 'King of Angmar long ago, Sorcerer, Ringwraith, Lord of the Nazgul, a spear of terror in<br>the hand of Sauron, shadow of despair.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

