		unique: true
		side: Shadow
		culture: Wraith
		twilight: 5
		type: Minion
		race: Nazgul
		strength: 10
		vitality: 2
		site: 3
		keywords: Fierce
		effects: [
			{
				type: Modifier
				modifier: {
					type: ModifyStrength
					filter: character,InSkirmishAgainst(self)
					amount: {
						type: Conditional
						requires: {
							type: CanSpot
							filter: companion
							count: 6
						}
						true: {
							type: ForEachYouCanSpot
							filter: other,companion
							multiplier: -1
						}
						false: {
							type: ForEachYouCanSpot
							filter: other,Nazgul
							multiplier: -1
						}
					}
				}
			}
		]
		gametext: Fierce.<br>Each character skirmishing this minion is strength -1 for each other Nazgul you can spot (or -1 for each other companion you can spot if you can spot 6 companions).
		lore: "'The storm is coming. The Nazgul have crossed the River! Ride, ride! Wait not for the dawn! Let not the swift wait for the slow! Ride!'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
