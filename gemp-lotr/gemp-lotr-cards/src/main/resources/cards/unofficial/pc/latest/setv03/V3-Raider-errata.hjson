		title: Strength of Men
		unique: false
		side: Shadow
		culture: Raider
		twilight: 2
		type: Event
		timewords: Maneuver
		effects: [
			{
				type: event
				requires: {
					type: CanSpot
					filter: culture(raider)
					count: 2
				}
				effect: {
					type: If
					check: {
						type: Or
						requires: [
							{
								type: CanSpotBurdens
								amount: 5
							}
							{
								type: CanSpot
								filter: culture(raider)
								count: 6
							}
						]
					}
					true: {
						type: ReconcileHand
					}
					false: {
						type: Restore
						select: choose(culture(raider))
						count: 2
					}
				}
			}
		]
		gametext: Spot 2 [raider] cards to restore 2 [raider] cards (or reconcile your hand if you can spot 5 burdens or 6 [raider] cards).
		lore: "Hard fighting and long labour they had still; for the Southrons were bold men and grim, and fierce in despair; and the Easterlings were strong and war-hardened and asked for no quarter."
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

