	103_56: {
		cardInfo: {
			//id: 103_56.1
			parent: 103_56
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S056.1_card.jpg
			collInfo: V3_56
			rarity: _
		}
		title: Sandcraft Trap
		unique: false
		side: Shadow
		culture: Raider
		twilight: 3
		type: Event
		timewords: Assignment
		effects: [
			{
				type: event
				effect: [
					{
						type: Restore
						select: all(or(tracker,and(minion,ambush)))
						memorize: restoredMinions
					}
					{
						type: If
						check: [
							{
								type: HasCardInMemory
								memory: restoredMinions
							}
						]
						true: [
							{
								type: AddKeyword
								select: all(Southron)
								keyword: ambush
								amount: 1
								until: start(regroup)
							}
							{
								type: ModifyStrength
								select: all(Southron)
								amount: 1
								until: start(regroup)
							}
						]
					}
				]
			}
		]
		gametext: Restore all trackers and minions with ambush.  If you restored any, make each Southron <b>ambush (1)</b> and strength +1 until the regroup phase.
		lore: "'We were outnumbered, for Mordor has allied itself with the Easterlings and the cruel Haradrim; but it was not by numbers that we were defeated. A power was there that we have not felt before.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

	103_59: {
		cardInfo: {
