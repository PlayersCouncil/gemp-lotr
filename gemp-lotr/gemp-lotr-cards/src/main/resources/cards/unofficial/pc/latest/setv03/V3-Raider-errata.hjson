{

	103_41: {
		cardInfo: {
			//id: 103_41.1
			parent: 103_41
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S041.1_card.jpg
			collInfo: V3_41
			rarity: _
		}
		title: Bladetusk Charger
		unique: false
		side: Shadow
		culture: Raider
		twilight: 3
		type: Possession
		target: self
		keywords: Support Area
		effects: [
			{
				type: Trigger
				optional: false
				trigger: {
					type: startOfPhase
					phase: skirmish
				}
				requires: {
					type: canSpot
					filter: self,inSkirmish
				}
				effect: {
					type: AddThreats
					amount: {
						type: Conditional
						requires: {
							type: HasCardStacked
							count: 4
							filter: Southron
							on: self
						}
						true: 2
						false: 1
					}
				}
			}
			{
				type: activated
				phase: maneuver
				requires: [
					{
						type: canSpot
						filter: self,zone(support)
					}
				]
				cost: [
					{
						type: StackCardsFromPlay
						select: choose(Southron, Man)
						where: self
						count: AnyNonZero
					}
				]
				effect: [
					{
						type: turnIntoMinion
						select: self
						strength: 4
						vitality: 4
						keywords: [
							fierce
							mounted
							southron
						]
						until: EndOfTurn
					}
					{
						type: AddModifier
						modifier: {
							type: ModifyStrength
							filter: self
							amount: {
								type: ForEachStacked
								filter: Southron
								on: self
								multiplier: 4
							}
						}
						until: EndOfTurn
					}
					{
						type: AddModifier
						modifier: {
							type: AddKeyword
							filter: self
							keyword: ambush
							amount: {
								type: ForEachStacked
								filter: Southron
								on: self
							}
						}
						until: EndOfTurn
					}
				]
			}
		]
		gametext: Maneuver: Stack 1 or more Southron Men here to make this a <b>fierce</b> mounted Southron minion until the end of the turn that is strength +4 and <b>ambush (1)</b> for each Southron stacked here. At the start of each skirmish involving this minion, add a threat (or 2 threats if there are 4 Southrons stacked here).
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

