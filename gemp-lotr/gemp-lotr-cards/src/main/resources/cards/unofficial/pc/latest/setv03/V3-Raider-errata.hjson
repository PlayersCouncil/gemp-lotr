		title: Bladetusk Matriarch
		unique: true
		side: Shadow
		culture: Raider
		twilight: 5
		type: Artifact
		strength: 6
		vitality: 6
		target: self
		keywords: Support Area
		effects: [
			{
				type: Trigger
				optional: true
				trigger: {
					type: Played
					filter: Southron
				}
				effect: {
					type: Choice
					texts: [
						Stack a [raider] Man from play
						Stack a [raider] Man from hand
					]
					effects: [
						{
							type: StackCardsFromPlay
							select: choose(culture(raider),Man)
							where: self
						}
						{
							type: StackCardsFromHand
							select: choose(culture(raider),Man)
							where: self
						}
					]
				}
			}
			{
				type: activated
				phase: maneuver
				requires: [
					{
						type: canSpot
						filter: self,zone(support)
					}
				]
				cost: {
					type: RemoveTwilight
					amount: 6
				}
				effect: [
					{
						type: turnIntoMinion
						select: self
						strength: 6
						vitality: 6
						keywords: [
							fierce
							mounted
							southron
						]
						until: EndOfTurn
					}
					{
						type: AddModifier
						modifier: {
							type: ModifyStrength
							filter: self
							amount: {
								type: ForEachStacked
								filter: Southron
								on: self
								multiplier: 3
							}
						}
						until: EndOfTurn
					}
					{
						type: AddModifier
						modifier: {
							type: AddKeyword
							filter: self
							keyword: ambush
							amount: {
								type: ForEachStacked
								filter: Southron
								on: self
							}
						}
						until: EndOfTurn
					}
					{
						type: AddModifier
						modifier: {
							type: ModifyArcheryTotal
							side: Shadow
							amount: {
								type: ForEachStacked
								filter: Southron
								on: self
								limit: 6
							}
						}
						until: EndOfTurn
					}
				]
			}
		]
		gametext: Each time a Southron is played, you may stack a [raider] Man from play or hand here.<br>Maneuver: Remove (6) to make this artifact a <b>fierce</b> mounted Southron minion until the end of the turn that is strength +3 and <b>ambush (1)</b> for each Southron stacked on her. She adds 1 to the Shadow archery total for each Southron stacked on her (limit 6).
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

