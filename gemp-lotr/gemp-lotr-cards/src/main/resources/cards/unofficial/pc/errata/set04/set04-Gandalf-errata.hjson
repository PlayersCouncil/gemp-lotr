		title: Grown Suddenly Tall
		unique: false
		side: Free Peoples
		culture: Gandalf
		twilight: 0
		type: Event
		timewords: Response
		keywords: Spell
		effects: [
			{
				type: ResponseEvent
				trigger: {
					type: Moves
				}
				cost: {
					type: Spot
					filter: title(Gandalf)
				},
				effect: [
					{
						type: Hinder
						select: all(condition)
						memorize: hinderedCards
					}
					{
						type: AddTwilight
						amount: {
							type: ForEachInMemory
							memory: hinderedCards
							filter: side(Shadow)
						}
					}
				]
			}
		]
		gametext: <b>Spell</b>.<br>Spot Gandalf to hinder all conditions.  Add (1) for each Shadow condition hindered (limit (5)).
		lore: "His hood and grey rags were flung away. His white garments shone."
