	103_96: {
		cardInfo: {
			//id: 103_96.1
			parent: 103_96
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S096.1_card.jpg
			collInfo: V3_96
			rarity: _
		}
		title: Endless Night
		unique: true
		side: Shadow
		culture: Sauron
		twilight: 5
		type: Condition
		target: self
		keywords: [
			Twilight
			Support Area
		]
		effects: [
			{
				type: ExtraCost
				cost: [
					{
						type: Hinder
						select: choose(twilight, condition)
						count: 4
					}
				]
			}
			{
				type: Modifier
				modifier: {
					type: CantBeDiscarded
					filter: self
				}
			}
			{
				type: Modifier
				modifier: {
					type: CantBeHindered
					filter: self
				}
			}

			{
				type: Modifier
				modifier: {
					type: AddKeyword
					filter: Orc
					keyword: fierce
				}
			}

			{
				type: Modifier
				modifier: {
					type: AddKeyword
					filter: Troll
					keyword: enduring
				}
			}

			{
				type: Modifier
				modifier: {
					type: AddKeyword
					filter: Nazgul
					keyword: damage+1
				}
			}

			{
				type: Modifier
				modifier: {
					type: AddKeyword
					filter: your,Man
					keyword: archer
				}
			}

			{
				type: Modifier
				modifier: {
					type: AddKeyword
					filter: your,Uruk-hai
					keyword: archer
				}
			}

			{
				type: Activated
				phase: Shadow
				requires: {
					type: Or
					requires: [
						{
							type: Playable
							fromZone: DISCARD
							filter: name(Sauron)
							discount: {
								type: ForEachCultureToken
								culture: Sauron
								multiplier: -1
							}
						}
						{
							type: Playable
							fromZone: HAND
							filter: name(Sauron)
							discount: {
								type: ForEachCultureToken
								culture: Sauron
								multiplier: -1
							}
						}
					]
				}
				cost: {
					type: Hinder
					select: choose(your, hinderable, side(Shadow), support)
					count: {
						type: Range
						from: 0
						to: {
							type: ForEachYouCanSpot
							filter: your, hinderable, side(Shadow), support
						}
					}
					memorize: hinderedCards
				}
				effect: {
					type: Choice
					texts: [
						Play Sauron from hand
						Play Sauron from your discard pile
					]
					effects: [
						{
							type: PlayCardFromHand
							select: choose(name(Sauron))
							discount: {
								type: ForEachInMemory
								memory: hinderedCards
								multiplier: -1
							}
						}
						{
							type: PlayCardFromDiscard
							select: choose(name(Sauron))
							maxDiscount: {
								type: ForEachYouCanSpot
								filter: your, side(Shadow), support
								multiplier: -1
							}
							discount: {
								type: ForEachInMemory
								memory: hinderedCards
								multiplier: -1
							}
						}
					]
				}
			}
		]
		gametext: Twilight. To play, hinder 4 twilight conditions. This cannot be discarded or hindered. Orcs gain <b>fierce</b>. Trolls gain <b>enduring</b>. Nazgul gain <b>damage +1</b>. Your Men and Uruk-hai gain <b>archer</b>. <br>Shadow: Hinder X of your other Shadow support cards to play Sauron from your hand or discard pile; he is twilight cost -X.
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

	103_99: {
