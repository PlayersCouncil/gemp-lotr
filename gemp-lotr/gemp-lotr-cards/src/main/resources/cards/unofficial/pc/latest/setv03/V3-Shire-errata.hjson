		title: Flotsam
		unique: false
		side: Free Peoples
		culture: Shire
		twilight: 1
		type: Possession
		target: hasAttached(pipe)
		keywords: Pipeweed
		effects: [
			{
				type: Trigger
				optional: true
				trigger: {
					type: Played
					filter: self
				}
				effect: {
					type: ShuffleCardsFromDiscardIntoDrawDeck
					select: choose(or(pipe,pipeweed))
					count: 0-2
				}
			}
		]
		gametext: Pipeweed. Bearer must bear a pipe.<br>When you play this possession, you may shuffle up to 2 pipes or pipeweed from your discard pile into your draw deck.
		lore: "'We have heaps of it,' he said; 'and you can all pack as much as you wish, when we go.'"
