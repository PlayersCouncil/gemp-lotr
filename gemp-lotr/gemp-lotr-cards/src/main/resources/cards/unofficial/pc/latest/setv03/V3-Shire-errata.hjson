	103_117: {
		cardInfo: {
			//id: 103_117.1
			parent: 103_117
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S117.1_card.jpg
			collInfo: V3_117
			rarity: _
		}
		title: Sting
		subtitle: Sharp Elven-blade
		unique: true
		side: Free Peoples
		culture: Shire
		twilight: 1
		type: Possession
		strength: 1
		resistance: 1
		itemclass: Hand weapon
		target: Ring-bound,Hobbit
		effects: [
			{
				type: Activated
				phase: Skirmish
				requires: {
					type: CantSpot
					filter: companion
					count: 5
				}
				cost: {
					type: AddThreats
					amount: 1
				}
				effect: {
					type: ModifyStrength
					select: bearer
					amount: {
						type: ForEachThreat
						limit: 6
					}
				}
			}
			{
				type: Response
				trigger: {
					type: NewRingBearer
				}
				effect: {
					type: Transfer
					select: self
					where: choose(Hobbit,Ring-bearer)
					checkTarget: true
				}
			}
			{
				type: Response
				fromDiscard: true
				trigger: {
					type: NewRingBearer
				}
				effect: {
					type: PlayCardFromDiscard
					select: self
					on: Hobbit,Ring-bearer
				}
			}
		]
		gametext: Bearer must be a Ring-bound Hobbit. <br>Skirmish: If you cannot spot more than 4 companions, add a threat to make bearer strength +1 for each threat you can spot (limit +6). <br>Response: If The One Ring is transferred, play this on the new Ring-bearer.  You may use this ability from your discard pile.
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

	103_119: {
		cardInfo: {
			//id: 103_119.1
			parent: 103_119
			variant: ERRATA
			variantPath: errata/pc
			revision: 1
			image: sets/V3/LOTR-ENV3S119.1_card.jpg
			collInfo: V3_119
			rarity: _
		}
		title: Treasured Pipe
		unique: false
		side: Free Peoples
		culture: Shire
		twilight: 1
		type: Possession
		itemclass: Pipe
		target: companion
		effects: [
			{
				type: ToPlay
				requires: {
					type: CanSpot
					filter: or(pipe, and(unbound,Hobbit))
				}
			}
			{
				type: Activated
				phase: Fellowship
				cost: [
					{
						type: Discard
						select: choose(pipeweed)
						count: 2
					}
					{
						type: chooseHowManyToSpot
						filter: pipe
						memorize: spottedPipes
					}
				]
				effect: [
					{
						type: ModifyStrength
						count: {
							type: fromMemory
							memory: spottedPipes
						}
						amount: 1
						select: choose(companion)
						until: start(regroup)
					}
					{
						type: Hinder
						select: self
					}
				]
			}
		]
		gametext: To play, spot a pipe or an unbound Hobbit. Bearer must be a companion.<br>Fellowship: Discard 2 pipeweeds and spot X pipes to make X companions strength +1 until the regroup phase.  Hinder this pipe.
		lore: "'I keep a treasure or two near my skin, as precious as Rings to me. Here's one: my old wooden pipe.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

