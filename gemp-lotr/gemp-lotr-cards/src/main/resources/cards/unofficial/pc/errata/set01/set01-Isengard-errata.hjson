		title: Saruman's Power
		unique: false
		side: Shadow
		culture: Isengard
		twilight: 2
		type: Event
		timewords: Shadow
		keywords: Spell
		effects: {
			type: event
			cost: {
				type: Exert
				count: 1
				select: choose(culture(isengard),minion)
			}
			effect: [
				{
					type: Discard
					count: 1
					select: choose(side(Free Peoples), condition)
				}
				{
					type: Hinder
					select: all(condition)
				}
			]
		}
		gametext: <b>Spell</b>.<br>Exert an [isengard] minion to discard a Free Peoples condition and then hinder all conditions.
		lore: "The Uruks of Saruman are bred to be the instruments of his will, destroying his enemies with foul cruelty."
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}
	
	51_138: {
		cardInfo: {
			//id: 1_138.1
			parent: 1_138
			variant: ERRATA
			variantPath: promos/pc
			revision: 1
			image: errata/51_138.jpg
			collInfo: 1C138
			rarity: C
		}
		title: Saruman's Snows
		culture: isengard
		twilight: 2
		type: condition
		keyword: [
			spell
			weather
		]
		target: site
		effects: [
			{
				type: extraCost
				cost: {
					type: exert
					select: choose(culture(isengard),minion)
				}
			}
			{
				type: modifier
				modifier: {
					type: cantPlayPhaseEventsOrPhaseSpecialAbilities
					requires: [
						{
							type: location
							filter: hasAttached(self)
						}
						{
							type: canSpot
							filter: culture(isengard),minion,inSkirmish
						}
					]
					phase: skirmish
				}
			}
			{
				type: Trigger
				optional: false
				trigger: {
					type: endOfTurn
				}
				effect: {
					type: discard
					select: self
				}
			}
		]
		gametext: <b>Spell.</b> <b>Weather.</b> To play, exert an [isengard] minion. Plays on a site.<br>No player may play skirmish events or use skirmish special abilities during skirmishes involving an [isengard] minion at this site.<br>Discard this condition at the end of the turn.
		lore: ""
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}

