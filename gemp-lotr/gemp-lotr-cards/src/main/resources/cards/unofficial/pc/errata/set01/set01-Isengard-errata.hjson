	51_139: {
		cardInfo: {
			//id: 1_139.3
			parent: 1_139
			variant: ERRATA
			variantPath: promos/pc
			revision: 3
			image: errata/LOTR-EN01E139.2.jpg
			collInfo: 1R139
			rarity: R
		}
		title: Savagery To Match Their Numbers
		culture: isengard
		twilight: 1
		type: event
		timeword: skirmish
		effects: {
			type: event
			effect: {
				type: choice
				texts: [
					Make an Uruk-hai strength +2
					Make an Uruk-hai strength +2 (and +2 more and fierce until the regroup phase)
				]
				effects: [
					{
						type: modifyStrength
						select: choose(uruk-hai)
						amount: 2
					}
					{
						type: If
						check: {
							type: canSpot
							count: 5
							filter: companion
						}
						true: [
							{
								type: modifyStrength
								select: choose(uruk-hai)
								amount: 2
								memorize: chosenUrukHai
							}
							{
								type: modifyStrength
								select: memory(chosenUrukHai)
								amount: 2
								until: start(regroup)
							}
							{
								type: addKeyword
								select: memory(chosenUrukHai)
								keyword: fierce
								until: start(regroup)
							}
						]
					}
				]
			}
		}
		gametext: <b>Skirmish:</b> Make an Uruk-hai strength +2.\If you can spot 5 companions, also make it <b>fierce</b> and strength +2 more until the regroup phase).
		lore: Uruk-hai match their enemies' strength with their own feral rage.
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}
	
	51_142: {
		cardInfo: {
			//id: 1_142.1
			parent: 1_142
			variant: ERRATA
			variantPath: promos/pc
			revision: 1
			image: errata/LOTR-EN01E142.1.jpg
			collInfo: 1U142
			rarity: U
		}
		title: Traitor's Voice
		unique: false
		side: Shadow
		culture: Isengard
		twilight: 2
		type: Condition
		keywords: [
			Search
			Support Area
		]
		effects: [
			{
				type: toPlay
				requires: {
					type: canSpot
					filter: isengard, minion
				}
			}
			{
				type: Trigger
				optional: false
				trigger: {
					type: ConstantlyCheck
					requires: [
						{
							type: perTurnLimit
							limit: 1
						}
						{
							type: or
							requires: [
								{
									type: CanSpot
									filter: Isengard, minion
									count: 4
								}
								{
									type: canSpot
									filter: exhausted,ring bearer
								}
								{
									type: canSpotBurdens
									amount: 5
								}
							]
						}
					]
				}
				effect: [
					{
						type: incrementPerTurnLimit
						limit: 1
					}
					{
						type: addModifier
						modifier: {
							type: modifyMoveLimit
							amount: -1
						}
						until: endOfTurn
					}
				]
			}
		]
		gametext: <b>Search</b>. To play, spot an [isengard] minion.\Regroup: Spot 4 [isengard] minions, an exhausted Ring-bearer, or 5 burdens to make the move limit for this turn -1 (limit once per phase).
		lore: "'In all the long wars with the Dark Tower treason has ever been our greatest foe.'"
		promotext: ""
		alts: {
			promos: {
			}
			errata: {
			}
		}
	}
	
